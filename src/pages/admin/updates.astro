---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import UpdatesPanel from '../../plugins/updater/UpdatesPanel';
---
<AdminLayout title="Atualizações" activeSection="updates">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900">Atualizações</h1>
        <p class="text-slate-500 mt-1">Mantenha o template sempre atualizado com as últimas melhorias.</p>
    </div>
    <UpdatesPanel client:load />
</AdminLayout>
