---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import PluginUpdatesPanel from '../../plugins/updater/PluginUpdatesPanel';
---
<AdminLayout title="Plugins — Instalar & Atualizar" activeSection="plugin-updates">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900">Instalar & Atualizar Plugins</h1>
        <p class="text-slate-500 mt-1">Gerencie as versões dos plugins instalados no seu Walker.</p>
    </div>
    <PluginUpdatesPanel client:load />
</AdminLayout>
