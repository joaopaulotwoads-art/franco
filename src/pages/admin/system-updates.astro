---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import SystemUpdater from '../../plugins/updater/SystemUpdater';
---
<AdminLayout title="Atualizações do Sistema" activeSection="updates">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900">Atualizações do Sistema</h1>
        <p class="text-slate-500 mt-1">Atualize o template e os plugins com um clique.</p>
    </div>
    <SystemUpdater client:load />
</AdminLayout>
