---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import { readData } from '../lib/readData';
const termsData = readData('terms.json');
---

<BaseLayout
  title={termsData.title}
  description={`Leia nossos ${termsData.title.toLowerCase()} e condições de uso.`}
>

  <section class="max-w-6xl mx-auto px-4 py-10">
    <div class="mb-6">
      <h1 class="text-3xl font-bold" style="font-family: var(--font-heading);">{termsData.title}</h1>
      <nav class="text-sm text-gray-500 mt-1" aria-label="breadcrumb">
        <a href="/" class="hover:text-gray-700">Home</a>
        <span class="mx-2">/</span>
        <span class="text-gray-700">{termsData.title}</span>
      </nav>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
      <div class="flex-1 min-w-0">
        <div class="bg-white rounded-xl border border-gray-200 p-6">

          {termsData.lastUpdated && (
            <p class="mb-6 text-sm text-gray-500">Última atualização: {termsData.lastUpdated}</p>
          )}

          <div class="space-y-6 text-gray-700 leading-relaxed">
            {termsData.content?.map((section: { title: string; text: string }) => (
              <div>
                <h2 class="text-lg font-bold mb-2 text-gray-900" style="font-family: var(--font-heading);">{section.title}</h2>
                <p class="text-gray-700">{section.text}</p>
              </div>
            ))}
          </div>

          <hr class="my-8 border-gray-200" />
          <p class="text-gray-700">
            Para dúvidas sobre estes termos, entre em <a href="/contato" class="text-[--color-primary] font-medium hover:underline">contato conosco</a>.
          </p>
        </div>
      </div>

      <aside class="lg:w-80 flex-shrink-0">
        <Sidebar />
      </aside>
    </div>
  </section>

</BaseLayout>
