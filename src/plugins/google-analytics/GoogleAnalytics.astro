---
/**
 * GoogleAnalytics.astro — Plugin Google Analytics
 *
 * Injeta o snippet gtag.js no <head> de todas as páginas públicas.
 * Lê o measurementId de src/data/pluginsConfig.json via readData().
 * Se cookieConsent.enabled for true, aguarda o evento 'cookies-accepted'
 * ou verifica localStorage antes de carregar o script.
 * Se measurementId estiver vazio, não renderiza nada.
 */
import { readData } from '../../lib/readData';

const pluginsConfig = readData('pluginsConfig.json', {}) as any;
const measurementId: string = pluginsConfig?.googleAnalytics?.measurementId || '';
const requireConsent: boolean = pluginsConfig?.cookieConsent?.enabled !== false;
---

{measurementId && (
  <script define:vars={{ measurementId, requireConsent }}>
  (function() {
    function loadGA() {
      if (window.__ga_loaded) return;
      window.__ga_loaded = true;
      var s = document.createElement('script');
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtag/js?id=' + measurementId;
      document.head.appendChild(s);
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', measurementId);
    }

    if (!requireConsent || localStorage.getItem('cookies-accepted') === 'true') {
      loadGA();
    } else {
      window.addEventListener('cookies-accepted', loadGA, { once: true });
    }
  })();
  </script>
)}
