{enabled && (
  <script>
  (function() {
    const dataEl = document.getElementById('aff-data');
    if (!dataEl) return;

    let parsed: any;
    try { parsed = JSON.parse(dataEl.textContent || '{}'); } catch { return; }

    const { products, config } = parsed as {
      products: any[];
      config: any;
    };

    if (!products || !products.length) return;

    const productMap: Record<string, any> = {};
    products.forEach((p: any) => { productMap[p.slug] = p; });

    const buttonColor = config?.buttonColor || '#FF9900';
    const defaultButtonText = config?.defaultButtonText || 'Ver na Amazon';
    const amazonTag = config?.amazonTag || '';
    const showPrices = config?.showPrices !== false;
    const showRatings = config?.showRatings !== false;
    const showProscons = config?.showProscons !== false;
    const showBadges = config?.showBadges !== false;
    const showDisclaimer = config?.showDisclaimer !== false;
    const disclaimer = config?.disclaimer || '';

    function appendTag(url: string): string {
      if (!amazonTag || !url) return url;
      try {
        const u = new URL(url);
        u.searchParams.set('tag', amazonTag);
        return u.toString();
      } catch {
        const sep = url.includes('?') ? '&' : '?';
        return `${url}${sep}tag=${amazonTag}`;
      }
    }

    function decodeAffiliateLinksParam(b64: string | undefined) {
      if (!b64 || !String(b64).trim()) return null;
      try {
        const pad = b64.length % 4 === 0 ? '' : '='.repeat(4 - (b64.length % 4));
        const normalized = String(b64).replace(/-/g, '+').replace(/_/g, '/') + pad;
        const raw = atob(normalized);
        const bytes = new Uint8Array(raw.length);
        for (let i = 0; i < raw.length; i++) bytes[i] = raw.charCodeAt(i);
        const json = new TextDecoder().decode(bytes);
        const arr = JSON.parse(json);
        return Array.isArray(arr) ? arr : null;
      } catch {
        return null;
      }
    }

    function mergeProductWithInlineLinks(p: any, linksB64: string | undefined) {
      if (!p || !linksB64) return p;
      const parsed = decodeAffiliateLinksParam(linksB64);
      if (!parsed || !parsed.length) return p;
      const cleaned = parsed.filter((l: any) => l && l.label && l.url);
      if (!cleaned.length) return p;
      return { ...p, extraLinks: cleaned };
    }

    function storeClassForLabel(label: string) {
      const l = (label || '').toLowerCase();
      if (l.includes('mercado') || l.includes('meli')) return 'aff-store-ml';
      if (l.includes('magalu') || l.includes('magazine')) return 'aff-store-magalu';
      if (l.includes('shopee')) return 'aff-store-shopee';
      return 'aff-store-generic';
    }

    function appendAffiliateExtraLinks(container: HTMLElement, p: any) {
      if (!p.extraLinks || !p.extraLinks.length) return;
      const wrap = document.createElement('div');
      wrap.className = 'aff-aff-extra-wrap';
      p.extraLinks.forEach((link: { label: string; url: string }) => {
        if (!link.label || !link.url) return;
        const a = document.createElement('a');
        a.className = 'aff-cta-secondary ' + storeClassForLabel(link.label);
        a.href = link.url;
        a.target = '_blank';
        a.rel = 'nofollow noopener sponsored';
        a.textContent = link.label + ' →';
        wrap.appendChild(a);
      });
      if (wrap.children.length) container.appendChild(wrap);
    }

    function renderStars(rating: number): string {
      const full = Math.floor(rating);
      const half = rating % 1 >= 0.5;
      let s = '';
      for (let i = 0; i < 5; i++) {
        if (i < full) s += '★';
        else if (i === full && half) s += '½';
        else s += '☆';
      }
      return s;
    }

    function buildProductBox(p: any): HTMLElement {
      const wrap = document.createElement('div');
      wrap.className = 'aff-box';

      const badgeText = p.badge || '';
      if (showBadges && badgeText) {
        const badge = document.createElement('div');
        badge.className = 'aff-badge';
        badge.textContent = badgeText;
        wrap.appendChild(badge);
      }

      const body = document.createElement('div');
      body.className = 'aff-body';

      if (p.image) {
        const imgWrap = document.createElement('div');
        imgWrap.className = 'aff-image-wrap';
        const img = document.createElement('img');
        img.src = p.image;
        img.alt = p.title || '';
        img.loading = 'lazy';
        imgWrap.appendChild(img);
        body.appendChild(imgWrap);
      }

      const info = document.createElement('div');
      info.className = 'aff-info';

      const title = document.createElement('p');
      title.className = 'aff-title';
      title.textContent = p.title || '';
      info.appendChild(title);

      if (showRatings && p.rating) {
        const stars = document.createElement('div');
        stars.className = 'aff-stars';
        stars.innerHTML = renderStars(p.rating) + `<span>${Number(p.rating).toFixed(1)}/5</span>`;
        info.appendChild(stars);
      }

      if (showPrices && p.price) {
        const prices = document.createElement('div');
        prices.className = 'aff-prices';
        const price = document.createElement('span');
        price.className = 'aff-price';
        price.textContent = p.price;
        prices.appendChild(price);
        if (p.originalPrice) {
          const orig = document.createElement('span');
          orig.className = 'aff-original-price';
          orig.textContent = p.originalPrice;
          prices.appendChild(orig);
        }
        info.appendChild(prices);
      }

      if (p.description) {
        const desc = document.createElement('p');
        desc.className = 'aff-desc';
        desc.textContent = p.description;
        info.appendChild(desc);
      }

      if (showProscons && ((p.pros && p.pros.length) || (p.cons && p.cons.length))) {
        const pc = document.createElement('div');
        pc.className = 'aff-proscons';

        if (p.pros && p.pros.length) {
          const prosCol = document.createElement('div');
          prosCol.className = 'aff-pros';
          const prosTitle = document.createElement('div');
          prosTitle.className = 'aff-pros-title';
          prosTitle.textContent = 'Prós';
          prosCol.appendChild(prosTitle);
          const ul = document.createElement('ul');
          p.pros.forEach((item: string) => {
            const li = document.createElement('li');
            li.textContent = item;
            ul.appendChild(li);
          });
          prosCol.appendChild(ul);
          pc.appendChild(prosCol);
        }

        if (p.cons && p.cons.length) {
          const consCol = document.createElement('div');
          consCol.className = 'aff-cons';
          const consTitle = document.createElement('div');
          consTitle.className = 'aff-cons-title';
          consTitle.textContent = 'Contras';
          consCol.appendChild(consTitle);
          const ul = document.createElement('ul');
          p.cons.forEach((item: string) => {
            const li = document.createElement('li');
            li.textContent = item;
            ul.appendChild(li);
          });
          consCol.appendChild(ul);
          pc.appendChild(consCol);
        }

        info.appendChild(pc);
      }

      body.appendChild(info);
      wrap.appendChild(body);

      const ctaWrap = document.createElement('div');
      ctaWrap.className = 'aff-cta-wrap';

      const cta = document.createElement('a');
      cta.className = 'aff-cta';
      cta.href = appendTag(p.amazonUrl || '#');
      cta.target = '_blank';
      cta.rel = 'nofollow noopener sponsored';
      cta.style.background = buttonColor;
      cta.textContent = (p.buttonText || defaultButtonText) + ' →';
      ctaWrap.appendChild(cta);
      appendAffiliateExtraLinks(ctaWrap, p);

      wrap.appendChild(ctaWrap);

      return wrap;
    }

    function parseTableBadges(raw: string | undefined, n: number): string[] {
      if (!raw || !raw.trim()) return Array(n).fill('');
      const parts = raw.split('|');
      while (parts.length < n) parts.push('');
      return parts.slice(0, n).map(s => s.replace(/\\"/g, '"').trim());
    }

    function buildTable(slugs: string[], badgeList: string[]): HTMLElement {
      const wrap = document.createElement('div');
      wrap.className = 'aff-table-wrap';

      const scroll = document.createElement('div');
      scroll.className = 'aff-table-scroll';
      const table = document.createElement('table');
      table.className = 'aff-table';
      const thead = document.createElement('thead');
      const trh = document.createElement('tr');
      ['Imagem', 'Produto', 'Avaliação', 'Preço', 'Comprar'].forEach(label => {
        const th = document.createElement('th');
        th.textContent = label;
        trh.appendChild(th);
      });
      thead.appendChild(trh);
      table.appendChild(thead);
      const tbody = document.createElement('tbody');

      const cardsWrap = document.createElement('div');
      cardsWrap.className = 'aff-table-cards';

      slugs.forEach((rawSlug, idx) => {
        const slug = String(rawSlug || '').trim();
        const p = productMap[slug];
        if (!p) return;
        const badge = (badgeList[idx] || '').trim();

        const tr = document.createElement('tr');

        const tdImg = document.createElement('td');
        tdImg.className = 'aff-td-img';
        const imgInner = document.createElement('div');
        imgInner.className = 'aff-td-img-inner';
        if (p.image) {
          const img = document.createElement('img');
          img.src = p.image;
          img.alt = p.title || '';
          img.loading = 'lazy';
          imgInner.appendChild(img);
        }
        if (badge) {
          const bEl = document.createElement('span');
          bEl.className = 'aff-row-badge';
          bEl.textContent = badge;
          imgInner.appendChild(bEl);
        }
        tdImg.appendChild(imgInner);
        tr.appendChild(tdImg);

        const tdTitle = document.createElement('td');
        tdTitle.className = 'aff-td-title';
        tdTitle.textContent = p.title || '';
        tr.appendChild(tdTitle);

        const tdStars = document.createElement('td');
        tdStars.className = 'aff-td-stars';
        if (showRatings && p.rating) {
          const span = document.createElement('span');
          span.innerHTML = renderStars(p.rating) + ' <span class="num">' + Number(p.rating).toFixed(1) + '/5</span>';
          tdStars.appendChild(span);
        } else {
          tdStars.textContent = '—';
        }
        tr.appendChild(tdStars);

        const tdPrice = document.createElement('td');
        tdPrice.className = 'aff-td-price';
        if (showPrices && p.price) {
          tdPrice.appendChild(document.createTextNode(p.price));
          if (p.originalPrice) {
            const del = document.createElement('del');
            del.textContent = p.originalPrice;
            tdPrice.appendChild(del);
          }
        } else {
          tdPrice.textContent = '—';
        }
        tr.appendChild(tdPrice);

        const tdCta = document.createElement('td');
        tdCta.className = 'aff-td-cta-stack';
        const ctaStack = document.createElement('div');
        ctaStack.className = 'aff-td-cta-inner';
        const cta = document.createElement('a');
        cta.className = 'aff-table-cta' + (idx % 2 === 1 ? ' alt-green' : '');
        cta.href = appendTag(p.amazonUrl || '#');
        cta.target = '_blank';
        cta.rel = 'nofollow noopener sponsored';
        cta.textContent = (p.buttonText || defaultButtonText) + ' →';
        ctaStack.appendChild(cta);
        appendAffiliateExtraLinks(ctaStack, p);
        tdCta.appendChild(ctaStack);
        tr.appendChild(tdCta);

        tbody.appendChild(tr);

        const card = document.createElement('div');
        card.className = 'aff-table-card';
        const top = document.createElement('div');
        top.className = 'aff-table-card-top';
        if (p.image) {
          const cimg = document.createElement('img');
          cimg.src = p.image;
          cimg.alt = '';
          cimg.loading = 'lazy';
          top.appendChild(cimg);
        }
        const textCol = document.createElement('div');
        textCol.style.flex = '1';
        textCol.style.minWidth = '0';
        if (badge) {
          const bb = document.createElement('span');
          bb.className = 'aff-row-badge';
          bb.style.display = 'inline-block';
          bb.style.marginBottom = '0.35rem';
          bb.textContent = badge;
          textCol.appendChild(bb);
        }
        const h4 = document.createElement('h4');
        h4.textContent = p.title || '';
        textCol.appendChild(h4);
        const meta = document.createElement('div');
        meta.className = 'aff-table-card-meta';
        let metaHtml = '';
        if (showRatings && p.rating) metaHtml += renderStars(p.rating) + ' ' + Number(p.rating).toFixed(1) + '/5';
        if (showPrices && p.price) {
          if (metaHtml) metaHtml += ' · ';
          metaHtml += '<strong style="color:#b45309">' + p.price + '</strong>';
          if (p.originalPrice) metaHtml += ' <del style="color:#94a3b8">' + p.originalPrice + '</del>';
        }
        meta.innerHTML = metaHtml || '—';
        textCol.appendChild(meta);
        top.appendChild(textCol);
        card.appendChild(top);
        const btnStack = document.createElement('div');
        btnStack.className = 'aff-td-cta-inner';
        btnStack.style.marginTop = '0.75rem';
        const cta2 = document.createElement('a');
        cta2.className = 'aff-table-cta' + (idx % 2 === 1 ? ' alt-green' : '');
        cta2.href = appendTag(p.amazonUrl || '#');
        cta2.target = '_blank';
        cta2.rel = 'nofollow noopener sponsored';
        cta2.textContent = (p.buttonText || defaultButtonText) + ' →';
        btnStack.appendChild(cta2);
        appendAffiliateExtraLinks(btnStack, p);
        card.appendChild(btnStack);
        cardsWrap.appendChild(card);
      });

      table.appendChild(tbody);
      scroll.appendChild(table);
      wrap.appendChild(scroll);
      wrap.appendChild(cardsWrap);
      return wrap;
    }

    function decodeComparisonData(b64) {
      if (!b64 || !String(b64).trim()) return null;
      try {
        const pad = b64.length % 4 === 0 ? '' : '='.repeat(4 - (b64.length % 4));
        const normalized = String(b64).replace(/-/g, '+').replace(/_/g, '/') + pad;
        const raw = atob(normalized);
        const bytes = new Uint8Array(raw.length);
        for (let i = 0; i < raw.length; i++) bytes[i] = raw.charCodeAt(i);
        const json = new TextDecoder().decode(bytes);
        return JSON.parse(json);
      } catch {
        return null;
      }
    }

    function buildTopComparison(slugsRaw, dataObj) {
      const wrap = document.createElement('div');
      wrap.className = 'aff-top-wrap';
      const grid = document.createElement('div');
      grid.className = 'aff-top-grid';

      const slugs = (slugsRaw || []).map(function (s) { return String(s || '').trim(); }).filter(Boolean).slice(0, 3);
      const badges = dataObj && Array.isArray(dataObj.badges) ? dataObj.badges : ['', '', ''];
      const subtitles = dataObj && Array.isArray(dataObj.subtitles) ? dataObj.subtitles : ['', '', ''];
      const specsList = dataObj && Array.isArray(dataObj.specs) ? dataObj.specs : [[], [], []];

      slugs.forEach(function (slug, idx) {
        const p = productMap[slug];
        if (!p) return;

        const card = document.createElement('div');
        card.className = 'aff-top-card';

        const badgeTxt = String(badges[idx] || '').trim();
        if (badgeTxt) {
          const badgeEl = document.createElement('div');
          badgeEl.className = 'aff-top-badge';
          badgeEl.textContent = badgeTxt;
          card.appendChild(badgeEl);
        }

        if (p.image) {
          const imgW = document.createElement('div');
          imgW.className = 'aff-top-img-wrap';
          const img = document.createElement('img');
          img.src = p.image;
          img.alt = p.title || '';
          img.loading = 'lazy';
          imgW.appendChild(img);
          card.appendChild(imgW);
        }

        const title = document.createElement('h3');
        title.className = 'aff-top-title';
        title.textContent = p.title || '';
        card.appendChild(title);

        const sub = String(subtitles[idx] || '').trim();
        if (sub) {
          const subEl = document.createElement('p');
          subEl.className = 'aff-top-sub';
          subEl.textContent = sub;
          card.appendChild(subEl);
        }

        if (showPrices && p.price) {
          const priceEl = document.createElement('div');
          priceEl.className = 'aff-top-price';
          priceEl.appendChild(document.createTextNode(p.price));
          if (p.originalPrice) {
            const del = document.createElement('del');
            del.textContent = p.originalPrice;
            priceEl.appendChild(del);
          }
          card.appendChild(priceEl);
        }

        const specs = specsList[idx] && Array.isArray(specsList[idx]) ? specsList[idx] : [];
        if (specs.length > 0) {
          const ul = document.createElement('ul');
          ul.className = 'aff-top-specs';
          specs.forEach(function (line) {
            const t = String(line || '').trim();
            if (!t) return;
            const li = document.createElement('li');
            li.textContent = t;
            ul.appendChild(li);
          });
          if (ul.children.length) card.appendChild(ul);
        }

        const cta = document.createElement('a');
        cta.className = 'aff-top-cta c' + (idx + 1);
        cta.href = appendTag(p.amazonUrl || '#');
        cta.target = '_blank';
        cta.rel = 'nofollow noopener sponsored';
        cta.textContent = (p.buttonText || defaultButtonText) + ' →';
        card.appendChild(cta);
        appendAffiliateExtraLinks(card, p);

        grid.appendChild(card);
      });

      wrap.appendChild(grid);
      return wrap;
    }

    function buildCompareCards(slugs: string[]): HTMLElement {
      const grid = document.createElement('div');
      grid.className = 'aff-compare-grid';

      slugs.forEach(slug => {
        const p = productMap[slug.trim()];
        if (!p) return;

        const card = document.createElement('div');
        card.className = 'aff-compare-card';

        if (p.image) {
          const img = document.createElement('img');
          img.src = p.image;
          img.alt = p.title || '';
          img.loading = 'lazy';
          card.appendChild(img);
        }

        const body = document.createElement('div');
        body.className = 'aff-compare-body';

        const title = document.createElement('p');
        title.className = 'aff-compare-title';
        title.textContent = p.title || '';
        body.appendChild(title);

        if (showRatings && p.rating) {
          const stars = document.createElement('div');
          stars.className = 'aff-compare-stars';
          stars.textContent = renderStars(p.rating) + ` ${Number(p.rating).toFixed(1)}`;
          body.appendChild(stars);
        }

        if (showPrices && p.price) {
          const price = document.createElement('div');
          price.className = 'aff-compare-price';
          price.textContent = p.price;
          body.appendChild(price);
        }

        const btnCol = document.createElement('div');
        btnCol.className = 'aff-compare-cta-stack';
        const cta = document.createElement('a');
        cta.className = 'aff-compare-cta';
        cta.href = appendTag(p.amazonUrl || '#');
        cta.target = '_blank';
        cta.rel = 'nofollow noopener sponsored';
        cta.style.background = buttonColor;
        cta.textContent = (p.buttonText || defaultButtonText) + ' →';
        btnCol.appendChild(cta);
        appendAffiliateExtraLinks(btnCol, p);
        body.appendChild(btnCol);

        card.appendChild(body);
        grid.appendChild(card);
      });

      return grid;
    }

    function processShortcodes() {
      const postContent = document.querySelector('.post-content');
      if (!postContent) return;

      const html = postContent.innerHTML;
      // Shortcodes can appear inside <p> tags — we need to replace the whole <p>
      const singleRe = /\[affiliate:([a-z0-9_-]+)\]/gi;
      const compareRe = /\[affiliate-compare:([a-z0-9_,\s-]+)\]/gi;

      // Collect all paragraphs and scan them
      const paragraphs = Array.from(postContent.querySelectorAll('p'));
      let foundAny = false;

      paragraphs.forEach(p => {
        const text = p.textContent || '';

        const singleMatch = text.match(/^\[affiliate:([a-z0-9_-]+)(?:\s+links="([^"]*)")?\]$/i);
        if (singleMatch) {
          let product = productMap[singleMatch[1]];
          if (product) {
            product = mergeProductWithInlineLinks(product, singleMatch[2]);
            const box = buildProductBox(product);
            p.replaceWith(box);
            foundAny = true;
            return;
          }
        }

        const compareMatch = text.match(/^\[affiliate-compare:([a-z0-9_,\s-]+)\]$/i);
        if (compareMatch) {
          const slugs = compareMatch[1].split(',').map((s: string) => s.trim()).filter(Boolean);
          const grid = buildCompareCards(slugs);
          p.replaceWith(grid);
          foundAny = true;
          return;
        }

        const tableMatch = text.match(/^\[affiliate_table\s+ids="([^"]+)"(?:\s+badges="([^"]*)")?\s*\]$/i);
        if (tableMatch) {
          const slugs = tableMatch[1].split(',').map((s: string) => s.trim()).filter(Boolean);
          const badges = parseTableBadges(tableMatch[2], slugs.length);
          const tableEl = buildTable(slugs, badges);
          p.replaceWith(tableEl);
          foundAny = true;
          return;
        }

        const topMatch = text.match(/^\[affiliate_comparison\s+ids="([^"]+)"(?:\s+data="([^"]*)")?\s*\]$/i);
        if (topMatch) {
          const slugs = topMatch[1].split(',').map((s: string) => s.trim()).filter(Boolean);
          const dataObj = decodeComparisonData(topMatch[2]);
          const topEl = buildTopComparison(slugs, dataObj);
          p.replaceWith(topEl);
          foundAny = true;
          return;
        }
      });

      // Also handle shortcodes not wrapped in <p> (raw text nodes)
      // by scanning innerHTML as fallback
      if (!foundAny) {
        const newHtml = postContent.innerHTML
          .replace(/\[affiliate_comparison\s+ids="([^"]+)"(?:\s+data="([^"]*)")?\s*\]/gi, (_: string, ids: string, dataRaw: string) => {
            const slugs = ids.split(',').map((s: string) => s.trim()).filter(Boolean);
            const dataObj = decodeComparisonData(dataRaw);
            return buildTopComparison(slugs, dataObj).outerHTML;
          })
          .replace(/\[affiliate_table\s+ids="([^"]+)"(?:\s+badges="([^"]*)")?\s*\]/gi, (_: string, ids: string, badgesRaw: string) => {
            const slugs = ids.split(',').map((s: string) => s.trim()).filter(Boolean);
            const badges = parseTableBadges(badgesRaw, slugs.length);
            return buildTable(slugs, badges).outerHTML;
          })
          .replace(/\[affiliate-compare:([a-z0-9_,\s-]+)\]/gi, (_: string, slugs: string) => {
            const grid = buildCompareCards(slugs.split(','));
            return grid.outerHTML;
          })
          .replace(/\[affiliate:([a-z0-9_-]+)(?:\s+links="([^"]*)")?\]/gi, (_: string, slug: string, linksRaw: string) => {
            let pr = productMap[slug];
            if (!pr) return _;
            pr = mergeProductWithInlineLinks(pr, linksRaw);
            return buildProductBox(pr).outerHTML;
          });
        if (newHtml !== postContent.innerHTML) {
          postContent.innerHTML = newHtml;
          foundAny = true;
        }
      }

      // Show disclaimer at top of post if there are affiliate products
      if (foundAny && showDisclaimer && disclaimer) {
        const disclaimerEl = document.createElement('div');
        disclaimerEl.className = 'aff-post-disclaimer';
        disclaimerEl.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><span>${disclaimer}</span>`;
        postContent.insertAdjacentElement('beforebegin', disclaimerEl);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', processShortcodes);
    } else {
      processShortcodes();
    }
  })();
  </script>
)}
