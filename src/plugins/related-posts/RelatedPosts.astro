---
/**
 * RelatedPosts.astro — Plugin Related Posts
 *
 * Exibe posts relacionados por categoria após o author box.
 * Filtra por mesma categoria, exclui post atual, embaralha e limita.
 */
import { getCollection } from 'astro:content';
import { readData } from '../../lib/readData';
import { postUrl } from '../../lib/blogRoutes';

interface Props {
  currentSlug: string;
  category: string;
  count?: number;
}

const { currentSlug, category, count } = Astro.props;

const pluginsConfig = readData('pluginsConfig.json', {}) as any;
const relatedConfig = pluginsConfig?.relatedPosts;
const enabled = relatedConfig?.enabled !== false;
const maxCount = count ?? relatedConfig?.count ?? 3;

let relatedPosts: any[] = [];

if (enabled && category) {
  const allPosts = await getCollection('blog');
  const filtered = allPosts.filter(p =>
    p.slug !== currentSlug &&
    p.data.category === category &&
    !p.data.draft
  );

  for (let i = filtered.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [filtered[i], filtered[j]] = [filtered[j], filtered[i]];
  }

  relatedPosts = filtered.slice(0, maxCount);
}
---

{enabled && relatedPosts.length > 0 && (
  <section class="mt-10 pt-8 border-t border-gray-200" aria-labelledby="related-posts-heading">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-2 mb-6">
      <h3 id="related-posts-heading" class="text-xl font-bold text-gray-900" style="font-family: var(--font-heading);">
        Artigos relacionados
      </h3>
      <img src="/images/wave.svg" class="h-3 w-24 object-contain opacity-60 hidden sm:block" alt="" aria-hidden="true" />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {relatedPosts.map((post) => {
        const postDate =
          post.data.pubDate instanceof Date
            ? post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })
            : new Date(post.data.pubDate).toLocaleDateString('pt-BR', {
                day: '2-digit',
                month: 'long',
                year: 'numeric',
              });
        const postCategory = post.data.category || '';
        const href = postUrl(post.slug);
        return (
          <article class="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm hover:shadow-md transition-shadow flex flex-col">
            <a href={href} class="block relative aspect-[16/10] overflow-hidden bg-gray-100 shrink-0">
              {post.data.heroImage ? (
                <img
                  src={post.data.heroImage}
                  alt={post.data.title}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200" />
              )}
              {postCategory && (
                <span class="category-badge absolute top-3 left-3">{postCategory}</span>
              )}
            </a>
            <div class="p-4 flex flex-col flex-1 min-h-0">
              <p class="text-xs text-gray-400 mb-2">{postDate}</p>
              <h4 class="text-base font-bold leading-snug mb-2" style="font-family: var(--font-heading);">
                <a href={href} class="text-gray-900 hover:text-[--color-primary] transition-colors">
                  {post.data.title}
                </a>
              </h4>
              {post.data.description && (
                <p class="text-sm text-gray-500 line-clamp-3 flex-1">{post.data.description}</p>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </section>
)}
